# =============================================================================
# Absolute Beginner Configuration File (.env)
# =============================================================================
# Rename this file to .env before starting the bot.

# ---------------------------------------------------------------------------
# 1. Your VICIdial Settings
# ---------------------------------------------------------------------------
VICIDIAL_API_URL=https://taurusbot.dialerhosting.com
VICIDIAL_API_USER=voicebot_api
VICIDIAL_API_PASS=your_api_password_here
VICIDIAL_TRANSFER_EXT=8300             # The extension your human closers sit at

# ---------------------------------------------------------------------------
# 2. Your SIP Settings (Connecting Bot to Phone System)
# ---------------------------------------------------------------------------
SIP_LOCAL_IP=YOUR_VAST_AI_PUBLIC_IP_HERE # Look for "IP Address" on Vast.ai dashboard
SIP_PORT=5060
SIP_USERNAME=voicebot
SIP_PASSWORD=your_secure_password_here
SIP_SIMULATION_MODE=False              # Must be False for real production calls

# ---------------------------------------------------------------------------
# 3. Bot Capacity
# ---------------------------------------------------------------------------
LLM_MAX_CONCURRENT=1                   # Start with 1 for testing. Change to 25 when ready!
