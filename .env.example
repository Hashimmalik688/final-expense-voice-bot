# =============================================================================
# Final Expense Voice Bot — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- HuggingFace (for model downloads — get token at huggingface.co/settings/tokens) ---
HF_TOKEN=

# --- VICIdial ---
VICIDIAL_API_URL=https://your-vicidial-server.example.com
VICIDIAL_API_USER=
VICIDIAL_API_PASS=
VICIDIAL_CAMPAIGN_ID=
VICIDIAL_TRANSFER_EXT=8300
VICIDIAL_CLOSER_INGROUP=CLOSERS

# --- SIP ---
SIP_LOCAL_IP=127.0.0.1
SIP_PORT=5060
SIP_SERVER=your-sip-server.example.com
SIP_USERNAME=voicebot
SIP_PASSWORD=

# --- LLM (vLLM serves Llama-3.1-8B-Instruct on port 8000) ---
LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
VLLM_API_URL=http://127.0.0.1:8000
LLM_MAX_TOKENS=256
LLM_TEMPERATURE=0.6
LLM_MAX_CONCURRENT=1

# --- STT (Parakeet TDT in-process, path to local .nemo file) ---
STT_MODEL=/workspace/models/parakeet/parakeet-tdt-0.6b-v3.nemo
STT_DEVICE=cuda

# --- TTS (Kokoro v0.9 server on port 8001) ---
TTS_API_URL=http://127.0.0.1:8001
TTS_MODEL=kokoro-v0.9
TTS_VOICE_ID=af_heart
KOKORO_VOICE=af_heart
TTS_SAMPLE_RATE=24000
TTS_SPEED=0.88

# --- RAG (local MiniLM embedding model) ---
RAG_EMBEDDING_MODEL=/workspace/models/minilm
RAG_TOP_K=3

# --- App ---
API_HOST=0.0.0.0
API_PORT=9000
LOG_LEVEL=INFO
MAX_CALL_DURATION_S=600
SILENCE_TIMEOUT_S=10

# --- Public URL (set by start_ngrok.sh automatically) ---
# PUBLIC_URL=https://your-subdomain.ngrok-free.dev
