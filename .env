# =============================================================================
# Final Expense Voice Bot — Configuration
# =============================================================================

# --- HuggingFace (approved access to meta-llama/Llama-3.1-8B-Instruct) ---
HF_TOKEN=your_huggingface_token_here

# --- VICIdial ---
VICIDIAL_API_URL=https://taurusbot.dialerhosting.com
VICIDIAL_API_USER=voicebot_api
VICIDIAL_API_PASS=
VICIDIAL_CAMPAIGN_ID=
VICIDIAL_TRANSFER_EXT=8300
VICIDIAL_CLOSER_INGROUP=CLOSERS

# --- SIP (Twilio — phase 1 testing) ---
SIP_LOCAL_IP=47.186.29.91
SIP_PORT=5060
SIP_SERVER=llamabot.sip.us1.twilio.com
SIP_USERNAME=llamabot
SIP_PASSWORD=BotPass2024!

# --- LLM (vLLM serves Llama-3.1-8B-Instruct on port 8000) ---
LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
VLLM_API_URL=http://127.0.0.1:8000
LLM_MAX_TOKENS=256
LLM_TEMPERATURE=0.6
LLM_MAX_CONCURRENT=1

# --- STT (Parakeet TDT in-process) ---
STT_MODEL=/workspace/models/parakeet/parakeet-tdt-0.6b-v3.nemo
STT_DEVICE=cuda

# --- TTS (CosyVoice2 server on port 8001) ---
TTS_API_URL=http://127.0.0.1:8001
TTS_MODEL=FunAudioLLM/CosyVoice2-0.5B
TTS_VOICE_ID=af_heart
KOKORO_VOICE=af_heart
TTS_SAMPLE_RATE=24000

# --- RAG ---
RAG_EMBEDDING_MODEL=/workspace/models/minilm
RAG_TOP_K=3

# --- App ---
API_HOST=0.0.0.0
API_PORT=9000
LOG_LEVEL=INFO
MAX_CALL_DURATION_S=600
