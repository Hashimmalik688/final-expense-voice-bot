# =============================================================================
# Final Expense Voice Bot — Configuration
# =============================================================================

# --- HuggingFace (approved access to meta-llama/Llama-3.1-8B-Instruct) ---
HF_TOKEN=your_huggingface_token_here

# --- VICIdial ---
VICIDIAL_API_URL=https://taurusbot.dialerhosting.com
VICIDIAL_API_USER=voicebot_api
VICIDIAL_API_PASS=
VICIDIAL_CAMPAIGN_ID=
VICIDIAL_TRANSFER_EXT=8300
VICIDIAL_CLOSER_INGROUP=CLOSERS

# --- SIP (Twilio — phase 1 testing) ---
SIP_LOCAL_IP=47.186.29.91
SIP_PORT=5060
SIP_SERVER=llamabot.sip.us1.twilio.com
SIP_USERNAME=llamabot
SIP_PASSWORD=BotPass2024!

# --- LLM (vLLM serves Llama-3.1-8B-Instruct on port 8000) ---
LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
VLLM_API_URL=http://127.0.0.1:8000
LLM_MAX_TOKENS=256
LLM_TEMPERATURE=0.6
LLM_MAX_CONCURRENT=1

# --- STT (Parakeet TDT in-process) ---
STT_MODEL=/workspace/models/parakeet/parakeet-tdt-0.6b-v3.nemo
STT_DEVICE=cuda

# --- TTS (Kokoro v0.9 server on port 8001) ---
TTS_API_URL=http://127.0.0.1:8001
TTS_MODEL=kokoro-v0.9
TTS_VOICE_ID=sarah_warm
KOKORO_VOICE=sarah_warm
TTS_SAMPLE_RATE=24000
TTS_SPEED=1.15

# --- RAG ---
RAG_EMBEDDING_MODEL=/workspace/models/minilm
RAG_TOP_K=3

# --- STT confidence gate ---
CONFIDENCE_THRESHOLD=0.55

# --- App ---
API_HOST=0.0.0.0
API_PORT=9000
LOG_LEVEL=DEBUG
MAX_CALL_DURATION_S=600
PUBLIC_URL=https://rivers-already-concerts-millennium.trycloudflare.com

# --- Audio pipeline tuning (all hot-configurable via .env + restart) ---
# Echo gate: ms to block audio AND discard STT after bot stops speaking
ECHO_GATE_MS=2000
# Pause before responding after caller utterance (ms) — give caller time to finish
EOT_PAUSE_MS=700
# Refractory period between barge-in events (seconds)
BARGE_IN_COOLDOWN_S=0.8
# Minimum inbound RMS (0-1) to trigger direct energy-based barge-in
BARGE_IN_ENERGY=0.015
# Silero VAD thresholds (tuned for 8kHz mu-law decoded to 16kHz float32)
VAD_THRESHOLD=0.35
VAD_MIN_SPEECH_MS=200
VAD_MIN_SILENCE_MS=300
VAD_ENERGY_THRESHOLD=0.002
VAD_MIN_SPEECH_DURATION_MS=150
